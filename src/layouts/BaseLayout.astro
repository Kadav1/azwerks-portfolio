---
import '../tokens/generated/tokens.css';
import '../styles/global.css';

interface Props {
  description?: string;
  title: string;
}

const {
  description = 'The greenfield foundation for the azwerks portfolio.',
  title,
} = Astro.props;

const themeBootstrap = `(()=>{try{const v=localStorage.getItem('azwerks.portfolio.theme.v1');if(v==='dark'||v==='light'){document.documentElement.dataset.theme=v}else{document.documentElement.removeAttribute('data-theme')}}catch{}})();`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <meta name="color-scheme" content="dark light" />
    <script is:inline set:html={themeBootstrap}></script>
    <title>{title}</title>
  </head>
  <body>
    <main id="main-content">
      <slot />
    </main>
  </body>
</html>
