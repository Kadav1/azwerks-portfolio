---
import '../styles/global.css';

interface Props {
  description?: string;
  title: string;
}

const {
  description = 'The greenfield foundation for the azwerks portfolio.',
  title,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
  </head>
  <body>
    <main>
      <slot />
    </main>
  </body>
</html>
