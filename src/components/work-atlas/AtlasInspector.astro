      <div><dt>Category</dt><dd data-atlas-inspector-category></dd></div>
      <div data-atlas-inspector-period-row><dt>Period</dt><dd data-atlas-inspector-period></dd></div>
      <div data-atlas-inspector-maintenance-row><dt>Maintenance</dt><dd data-atlas-inspector-maintenance></dd></div>
