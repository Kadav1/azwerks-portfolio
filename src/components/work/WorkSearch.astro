<div class="work-search">
  <label for="work-register-query">Search Work</label>
  <input
    id="work-register-query"
    name="q"
    type="search"
    maxlength="120"
    autocomplete="off"
    inputmode="search"
    aria-describedby="work-register-query-hint"
  />
  <p id="work-register-query-hint" class="work-controls__hint">
    Searches public titles, summaries, categories, tags, capabilities, platforms, and approved tools.
  </p>
</div>
