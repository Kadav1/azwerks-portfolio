---
import GlobalShell from '../../layouts/GlobalShell.astro';
import WorkRegister from '../../components/work/WorkRegister.astro';
import WorkRegisterHeader from '../../components/work/WorkRegisterHeader.astro';
import { getPublicProjectBundles } from '../../content-model/queries.ts';
import { createWorkRegisterRecords } from '../../lib/work-register/view-model.ts';
import '../../styles/work-register.css';

const bundles = await getPublicProjectBundles();
const records = createWorkRegisterRecords(bundles);
const hasDetailDestinations = records.some(({ href }) => href !== undefined);
---

<GlobalShell
  title="Work — azwerks"
  description="The canonical public register of current azwerks work."
  canonical="/work/"
  mainId="work"
  workResultsId="work-results"
  noindex={records.length === 0 || !hasDetailDestinations}
>
  <WorkRegisterHeader count={records.length} />
  <WorkRegister records={records} />
</GlobalShell>
