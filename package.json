{
  "name": "azwerks-portfolio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.16.0 <25",
    "npm": ">=11 <12"
  },
  "scripts": {
    "dev": "astro dev",
    "tokens:generate": "node scripts/generate-tokens.mjs",
    "tokens:validate:source": "node scripts/validate-token-source.mjs",
    "tokens:validate:references": "node scripts/validate-token-references.mjs",
    "tokens:validate:contrast": "node scripts/validate-token-contrast.mjs",
    "tokens:validate:runtime": "node scripts/validate-theme-runtime.mjs",
    "tokens:validate:usage": "node scripts/validate-token-usage.mjs",
    "tokens:check:generated": "node scripts/check-generated-tokens.mjs",
    "tokens:audit:browser": "node scripts/browser-token-foundation-audit.mjs",
    "tokens:check": "npm run tokens:validate:source && npm run tokens:validate:references && npm run tokens:validate:contrast && npm run tokens:validate:runtime && npm run tokens:validate:usage && npm run tokens:check:generated",
    "content:sync": "astro sync",
    "content:generate": "node scripts/generate-content-manifest.mjs",
    "content:test:unit": "node --test tests/content-model/*.test.mjs",
    "content:validate": "node scripts/validate-content-foundation.mjs",
    "content:test:invalid": "node scripts/test-invalid-content-fixtures.mjs",
    "content:check:generated": "node scripts/check-content-manifest.mjs",
    "content:check": "npm run content:sync && npm run content:test:unit && npm run content:validate && npm run content:test:invalid && npm run content:check:generated",
    "shell:test:unit": "node --test tests/shell/*.test.mjs",
    "shell:validate": "node scripts/validate-global-shell.mjs",
    "shell:audit:browser": "npm run build && node scripts/browser-global-shell-audit.mjs",
    "shell:check": "npm run shell:test:unit && npm run shell:validate",
    "register:validate": "node scripts/validate-work-register.mjs",
    "register:test:state": "node scripts/test-work-register-state.mjs",
    "register:audit:browser": "node scripts/browser-work-register-audit.mjs",
    "register:check": "npm run register:validate && npm run register:test:state",
    "detail:generate": "node scripts/generate-project-detail-manifest.mjs",
    "detail:validate": "node scripts/validate-project-detail.mjs",
    "detail:test:view-model": "node scripts/test-project-detail-view-model.mjs",
    "detail:check:generated": "node scripts/check-project-detail-manifest.mjs",
    "detail:audit:browser": "node scripts/browser-project-detail-audit.mjs",
    "detail:check": "npm run detail:validate && npm run detail:test:view-model && npm run detail:check:generated",
    "worlds:generate": "node scripts/generate-project-world-manifest.mjs",
    "worlds:validate": "node scripts/validate-project-worlds.mjs",
    "worlds:test": "node scripts/test-project-world-registry.mjs",
    "worlds:audit:browser": "node scripts/browser-project-worlds-audit.mjs",
    "worlds:check": "npm run worlds:validate && npm run worlds:test",
    "check:astro": "astro check",
    "check": "npm run tokens:check && npm run content:check && npm run shell:check && npm run register:check && npm run detail:check && npm run worlds:check && npm run check:astro",
    "build": "npm run tokens:check && npm run content:check && npm run shell:check && npm run register:check && npm run detail:check && npm run worlds:check && astro build",
    "preview": "astro preview",
    "validate": "npm run check"
  },
  "dependencies": {
    "astro": "7.0.9"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@types/node": "24.13.3",
    "typescript": "6.0.3"
  }
}
